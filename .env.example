# Скопируй в .env и заполни. Реальный .env — в .gitignore.

# --- security-lab (движок детекторов) ---
# Путь к репозиторию security-lab (содержит toolkit/recon.py).
# В docker он монтируется в контейнер как /security-lab (см. docker-compose.yml).
SECURITY_LAB_PATH=/path/to/security-lab

# --- LLM ---
# Ключ Anthropic (Claude). Без него дефолтный провайдер откатывается на Ollama.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
# Дефолтный провайдер: anthropic | ollama
DEFAULT_LLM_PROVIDER=anthropic
# Ollama (эмбеддинги + опциональный локальный LLM). В docker до Ollama на хосте —
# http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
EMBED_MODEL=nomic-embed-text
# Лимит расхода на прогон в USD (пусто — без лимита).
# LLM_BUDGET_USD=0.50

# --- RAG / Postgres ---
# Локально: localhost. В docker-compose переопределяется на хост `postgres`.
DATABASE_URL=postgresql://audit:audit@localhost:5432/audit
EMBED_DIMENSION=768

# --- API ---
# Токен для /audit и /search. Пусто — эндпоинты открыты (локальное демо).
# Задай перед публичным деплоем, чтобы чужие не тратили твой LLM-ключ.
# API_KEY=change-me
